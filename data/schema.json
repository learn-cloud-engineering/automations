{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["cohorts"],
  "properties": {
    "cohorts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "name", "status", "region", "students"],
        "properties": {
          "code": {
            "type": "string",
            "pattern": "^ce[0-9]{2}$",
            "description": "Cohort code, e.g. ce88"
          },
          "name": {
            "type": "string",
            "description": "Human-readable cohort name"
          },
          "status": {
            "type": "string",
            "enum": ["active", "inactive"],
            "description": "active = resources created, inactive = resources destroyed"
          },
          "region": {
            "type": "string",
            "enum": ["ap-southeast-1", "us-east-1"],
            "description": "AWS region for cohort resources"
          },
          "students": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "aws_username"],
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Student's full name"
                },
                "aws_username": {
                  "type": "string",
                  "description": "AWS IAM username (without cohort suffix)"
                },
                "github_username": {
                  "type": "string",
                  "description": "GitHub username"
                },
                "discord_username": {
                  "type": "string",
                  "description": "Discord username"
                }
              }
            }
          }
        }
      }
    }
  }
}
